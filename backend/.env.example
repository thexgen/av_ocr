# Legacy DashScope / Qwen (optional; unused when Bedrock is configured)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

ALLOW_LOCAL_MAPPER_FALLBACK=true
TEXT_PDF_CHAR_THRESHOLD=40

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=avfamily
MYSQL_CHARSET=utf8mb4

# Defaults for bankcashtemp staging
DEFAULT_ENTITY_ID=1
DEFAULT_ENTITY_NAME=Krishna Deval
DEFAULT_USER_ID=1

# Jessy RAG (local Qdrant for now; cloud later)
QDRANT_URL=http://localhost:6333

# Amazon Bedrock — Nova Lite (preferred LLM for Jessy + mapping)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-2
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
LLM_MAX_TOKENS=512
LLM_MAX_INPUT_CHARS=3000
