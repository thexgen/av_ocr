# DashScope / Qwen (OpenAI-compatible)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

ALLOW_LOCAL_MAPPER_FALLBACK=true
TEXT_PDF_CHAR_THRESHOLD=40

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=avfamily
MYSQL_CHARSET=utf8mb4

# Defaults for bankcashtemp staging
DEFAULT_ENTITY_ID=1
DEFAULT_ENTITY_NAME=Krishna Deval
DEFAULT_USER_ID=1
