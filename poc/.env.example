# DashScope / Qwen (OpenAI-compatible)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# If QWEN_API_KEY is empty, use local alias mapper (POC only)
ALLOW_LOCAL_MAPPER_FALLBACK=true

# Avg chars/page below this → treat as scanned
TEXT_PDF_CHAR_THRESHOLD=40
